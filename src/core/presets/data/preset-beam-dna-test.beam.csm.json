    { "id": "amp_x", "type": "MATH_BINARY", "position": { "x": 1000, "y": 50 }, "data": { "astType": "MATH_BINARY", "inputs": [{ "id": "a", "type": "float" }, { "id": "b", "type": "float", "value": 1.5 }, { "id": "op", "type": "string", "value": "multiply" }], "outputs": [{ "id": "out", "type": "float" }] } },
